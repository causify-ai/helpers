#!/usr/bin/env python
"""
Unified markdown file manager for research, blog, story, and skill content.

Provides a single interface to manage markdown files across multiple directories:
- skill: .claude/skills/ directory
- blog: blog/posts/ directory
- research: research/ideas/ directory
- story: short_stories/ directory

Usage:
  md <type> <action> [name]
    type:   research, blog, story, skill (prefix matching supported)
    action: list, edit, directory, describe (supports prefix matching)
    name:   optional for 'list' action (filter pattern), required for 'edit'

Examples:
  md sk list                     # List all skills
  md sk de                       # List all skills with descriptions
  md blog edit My_Post           # Edit or create a blog post
  md res l causal                # List research items containing 'causal'
  md res de causal               # List research items with descriptions
  md story dir                   # Print short stories directory path

Import as:

import dev_scripts_helpers.system_tools.md as devmd
"""

import argparse
import logging

import helpers.hdbg as hdbg
import helpers.hparser as hparser

import dev_scripts_helpers.system_tools.md_utils as devmduti

_LOG = logging.getLogger(__name__)

# #############################################################################
# Parser and main
# #############################################################################


def _parse() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "type",
        help="Type: research, blog, story, skill (supports prefix matching)",
    )
    parser.add_argument(
        "action",
        help="Action: list, edit, directory (supports prefix matching)",
    )
    parser.add_argument(
        "name",
        nargs="?",
        default=None,
        help="Name/pattern (optional for list, required for edit)",
    )
    hparser.add_verbosity_arg(parser)
    return parser


def _main(parser: argparse.ArgumentParser) -> None:
    args = parser.parse_args()
    logging.basicConfig(level=args.log_level)
    type_ = devmduti._match_prefix(args.type, devmduti._VALID_TYPES)
    action = devmduti._match_prefix(args.action, devmduti._VALID_ACTIONS)
    args.name = devmduti._normalize_name(args.name)
    dir_ = devmduti._get_directory(type_)
    if action == "list":
        devmduti._action_list(type_, dir_, pattern=args.name)
    elif action == "full_list":
        devmduti._action_full_list(type_, dir_, pattern=args.name)
    elif action == "describe":
        devmduti._action_describe(type_, dir_, pattern=args.name)
    elif action == "edit":
        hdbg.dassert_ne(
            args.name,
            None,
            "Name is required for edit action",
        )
        devmduti._action_edit(type_, dir_, args.name)
    elif action == "directory":
        devmduti._action_directory(dir_)
    else:
        hdbg.dfatal("Unknown action", action)


if __name__ == "__main__":
    _main(_parse())
