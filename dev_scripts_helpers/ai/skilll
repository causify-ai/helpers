#!/bin/bash -e
# """
# List available Claude Code skills in the .claude/skills/ directory.
#
# This script helps discover and filter available skills for the Claude Code
# CLI tool. Skills are custom commands that extend Claude Code functionality.
#
# Examples:
#   sf                     # List all skills
#   sf format              # List skills matching "format"
#   sf -f                  # List all skills with full paths
#   sf -f coding           # List coding skills with full paths
# """

show_help() {
    grep '^# ' "$0" | sed 's/^# //' | sed '1d'
}

# Find the git repository root.
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
REPO_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)"
skills_dir="$REPO_ROOT/.claude/skills"

full_path=false
pattern=""

# Parse arguments.
while [[ $# -gt 0 ]]; do
    case "$1" in
        -f)
            full_path=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            pattern="$1"
            shift
            ;;
    esac
done

if [[ ! -d "$skills_dir" ]]; then
    echo "Error: $skills_dir directory not found" >&2
    exit 1
fi

if [[ "$full_path" == true ]]; then
    # List with full paths.
    if [[ -n "$pattern" ]]; then
        find "$skills_dir" -maxdepth 1 -type d | grep "$pattern" | sort
    else
        find "$skills_dir" -maxdepth 1 -type d -not -name "skills" | sort
    fi
else
    # List with relative names only.
    if [[ -n "$pattern" ]]; then
        ls -1 "$skills_dir" | grep "$pattern"
    else
        ls -1 "$skills_dir"
    fi
fi
