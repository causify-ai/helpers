#!/bin/bash -e
# """
# Create a new blog post.
# """

# Make sure $1 contains a blog name (e.g., `My_New_Post`)
if [[ -z "$1" ]]; then
    echo "ERROR: Provide a blog name (e.g., My_New_Post)" >&2
    exit 1
fi
BLOG_NAME="$1"

# Find the blog/posts directory.
BLOG_DIR=$(find . -type d -path "*/blog/posts" 2>/dev/null | head -1)
if [[ -z "$BLOG_DIR" ]]; then
    echo "ERROR: Could not find blog/posts directory" >&2
    exit 1
fi

# Build the file path with draft prefix.
BLOG_FILE="$BLOG_DIR/draft.$BLOG_NAME.md"

# Check that the file doesn't already exist.
if [[ -f "$BLOG_FILE" ]]; then
    echo "ERROR: Blog post already exists: $BLOG_FILE" >&2
    exit 1
fi

# Get today's date.
TODAY=$(date +%Y-%m-%d)

# Create the blog post with frontmatter template.
cat > "$BLOG_FILE" <<EOF
---
draft: true
title: ""
authors:
  - gpsaggese
date: $TODAY
description:
categories:
  - Causal AI
---

TL;DR:

<!-- more -->
EOF

# Print the full path of the new blog post.
echo "$BLOG_FILE"
