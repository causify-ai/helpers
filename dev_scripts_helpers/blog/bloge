#!/bin/bash -e
# """
# Edit a blog post.
# """

if [[ -z "$1" ]]; then
    echo "ERROR: Provide a blog name or pattern (e.g., My_New_Post)" >&2
    exit 1
fi

# Find the blog/posts directory.
BLOG_DIR=$(find . -type d -path "*/blog/posts" 2>/dev/null | head -1)
if [[ -z "$BLOG_DIR" ]]; then
    echo "ERROR: Could not find blog/posts directory" >&2
    exit 1
fi

# Find matching files.
MATCHES=$(ls -1 "$BLOG_DIR" | grep "$1")
COUNT=$(echo "$MATCHES" | grep -c . || true)

if [[ "$COUNT" -eq 0 ]]; then
    echo "ERROR: No blog post found matching: $1" >&2
    exit 1
elif [[ "$COUNT" -gt 1 ]]; then
    echo "ERROR: Multiple matches found, be more specific:" >&2
    echo "$MATCHES" >&2
    exit 1
fi

vi "$BLOG_DIR/$MATCHES"
