#!/bin/bash -e
# """
# Open the blog README.
# """

# Find the script directory and look for README.md there.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
README="$SCRIPT_DIR/README.md"
if [[ ! -f "$README" ]]; then
    echo "ERROR: Could not find $README" >&2
    exit 1
fi

vi "$README"
