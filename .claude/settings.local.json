{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(python *)",
      "Bash(bash ./tmp.pytest_repro.*.sh)",
      "WebFetch(domain:*)",
      "Bash(gh pr view:*)",
      "Bash(python3 *)",
      "Bash(rtk grep *)",
      "Bash(rtk pytest *)",
      "Bash(rtk read *)",
      "Bash(rtk git *)"
    ],
    "deny": [
      "Bash(*git commit:*)",
      "Bash(*git commit -m *)",
      "Bash(*git push:*)"
    ]
  },
  "model": "haiku",
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "source notify2.sh --timeout 10 --title 'CC idle'"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "source notify2.sh --timeout 10 --title 'CC needs input'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "source notify2.sh --timeout 10 --title 'CC is stopped'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },
  "spinnerTipsEnabled": true
}